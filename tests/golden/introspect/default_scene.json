{
  "engine": {
    "name": "Hazard Forge",
    "version": "0.1.0",
    "backends": ["vulkan", "metal"],
    "activeBackend": "vulkan",
    "features": [
      "pbr-metallic-roughness",
      "image-based-lighting",
      "cascaded-shadow-maps",
      "spot-light-shadows",
      "point-light-shadows",
      "clustered-lighting",
      "screen-space-reflections",
      "screen-space-global-illumination",
      "decals",
      "post-process-stack",
      "volumetric-fog",
      "reflection-irradiance-probes",
      "temporal-anti-aliasing",
      "frustum-culling",
      "gpu-driven-culling",
      "gpu-multi-draw-indirect",
      "multithreaded-recording",
      "bloom",
      "ssao",
      "transparency",
      "hardware-instancing",
      "gpu-particles",
      "gltf-import",
      "skeletal-animation",
      "animation-blending",
      "animation-state-machine",
      "rigid-body-physics",
      "procedural-terrain",
      "debug-visualization",
      "interactive-runtime",
      "editor-selection-gizmos",
      "docked-editor",
      "automatic-barriers",
      "material-graph",
      "material-graph-introspection",
      "live-material-authoring",
      "gameplay-sample",
      "hud-text",
      "audio-mixer",
      "scene-streaming",
      "terrain-streaming-lod",
      "state-replication",
      "network-transport-sim"
    ]
  },
  "showcases": [
    { "flag": "--shot", "desc": "Default lit + shadowed scene (ground + grid + duck)." },
    { "flag": "--pbr-shot", "desc": "Full PBR showcase (DamagedHelmet, metallic-roughness)." },
    { "flag": "--material-shot", "desc": "Data-driven material graph (sphere shaded by showcase.mat.json)." },
    { "flag": "--material-live-shot", "desc": "Live runtime material authoring (runtime codegen+dxc compile, no rebuild)." },
    { "flag": "--material-multi-shot", "desc": "Multi-material scene (three spheres, each a distinct graph material)." },
    { "flag": "--material-normal-shot", "desc": "Tangent-space normal-mapped material graph (NormalMap node perturbs the shading normal)." },
    { "flag": "--material-introspect", "desc": "Dump a material graph as deterministic JSON (or DOT with --dot): nodes, params, typed ports, edges, resolved PBROutput." },
    { "flag": "--ibl-shot", "desc": "HDR image-based lighting (equirect skybox reflections)." },
    { "flag": "--scene-shot", "desc": "glTF scene-graph import (CesiumMilkTruck node hierarchy)." },
    { "flag": "--bloom-shot", "desc": "HDR bloom post-process." },
    { "flag": "--ssao-shot", "desc": "Screen-space ambient occlusion." },
    { "flag": "--skinning-shot", "desc": "Skeletal animation (GPU skinning)." },
    { "flag": "--blend-shot", "desc": "Animation blending between two clips." },
    { "flag": "--anim-fsm-shot", "desc": "Animation state machine (parameter-driven states + cross-fade blend)." },
    { "flag": "--instanced-shot", "desc": "Hardware-instanced grid." },
    { "flag": "--physics-shot", "desc": "Rigid-body physics (impulse solver)." },
    { "flag": "--terrain-shot", "desc": "Procedural terrain / heightmap (deterministic NxN displaced grid, lit + shadowed)." },
    { "flag": "--game-shot", "desc": "Playable game sample (deterministic roll-a-ball collect-the-pickups)." },
    { "flag": "--net-shot", "desc": "State replication (deterministic snapshot+delta; replica reconstructs the scene)." },
    { "flag": "--netsim-shot", "desc": "Simulated network transport + client jitter-buffer interpolation (seeded latency/loss/reorder; smoothing hides the lossy channel)." },
    { "flag": "--stream-shot", "desc": "Scene/asset streaming (distance-based cell residency + per-frame budget)." },
    { "flag": "--terrain-stream-shot", "desc": "Terrain streaming with per-tile LOD (distance-banded tile residency + LOD selection)." },
    { "flag": "--hud-shot", "desc": "Screen-space text / HUD overlay (baked 8x8 font, alpha-blended quads)." },
    { "flag": "--game-hud-shot", "desc": "Game scene with a live SCORE HUD overlay (own golden; game.png unchanged)." },
    { "flag": "--transparency-shot", "desc": "Sorted alpha-blended transparency." },
    { "flag": "--debug-shot", "desc": "Immediate-mode debug-line visualization." },
    { "flag": "--capstone-shot", "desc": "Capstone scene combining the major features." },
    { "flag": "--csm-shot", "desc": "Cascaded shadow maps (directional)." },
    { "flag": "--spot-shot", "desc": "Spot light with perspective shadow." },
    { "flag": "--point-shadow-shot", "desc": "Omnidirectional point-light shadow (cube map)." },
    { "flag": "--clustered-shot", "desc": "Clustered / Forward+ many-light shading." },
    { "flag": "--ssr-shot", "desc": "Screen-space reflections." },
    { "flag": "--ssgi-shot", "desc": "Screen-space global illumination (color-bleed indirect diffuse)." },
    { "flag": "--ssgi-denoise-shot", "desc": "SSGI bilateral spatial denoise (edge-preserving smoothing of the indirect-diffuse buffer)." },
    { "flag": "--ssgi-temporal-shot", "desc": "Temporal SSGI accumulation (fixed-N golden-angle-jittered indirect-diffuse averaging)." },
    { "flag": "--decal-shot", "desc": "Screen-space projected decals (top-down decal box on the ground)." },
    { "flag": "--poststack-shot", "desc": "Data-driven post-process stack (ordered tonemap/grade/chromatic/vignette/grain chain)." },
    { "flag": "--volumetric-shot", "desc": "Volumetric fog / light shafts." },
    { "flag": "--probe-shot", "desc": "Reflection + irradiance probes (local cubemap GI)." },
    { "flag": "--taa-shot", "desc": "Temporal anti-aliasing (jittered accumulation)." },
    { "flag": "--cull-shot", "desc": "Frustum culling visualization (overview camera + kept/culled bounds)." },
    { "flag": "--gpu-cull-shot", "desc": "GPU-driven culling + indirect draw (compute compaction, GPU draw count)." },
    { "flag": "--mdi-shot", "desc": "GPU multi-draw-indirect batching (144 objects in 1 draw; MDI==per-draw byte-identical)." },
    { "flag": "--mt-shot", "desc": "Multithreaded command recording (per-thread secondaries, 1-vs-N identical)." },
    { "flag": "--editor-shot", "desc": "Docked editor UI (Scene Hierarchy / Inspector / Stats panels around a central scene Viewport, fixed selected entity)." },
    { "flag": "--gizmo-shot", "desc": "Editor selection + translate gizmo overlay." },
    { "flag": "--camera-shot", "desc": "Scripted-pose interactive-runtime capture." },
    { "flag": "--audio-render", "desc": "Deterministic audio mixer (integer/fixed-point voices -> 16-bit PCM WAV)." }
  ],
  "commands": [
    { "op": "dump", "args": {} },
    { "op": "list", "args": {} },
    { "op": "set_transform", "args": {"entity": "int", "position": "[x,y,z]?", "euler": "[x,y,z]?", "scale": "[x,y,z]?"} },
    { "op": "set_material", "args": {"entity": "int", "metallic": "float?", "roughness": "float?", "baseColor": "string|null?", "normalMap": "string|null?"} },
    { "op": "add", "args": {"mesh": "string", "baseColor": "string|null?", "normalMap": "string|null?", "metallic": "float?", "roughness": "float?", "position": "[x,y,z]?", "euler": "[x,y,z]?", "scale": "[x,y,z]?"} },
    { "op": "remove", "args": {"entity": "int"} },
    { "op": "capture", "args": {"path": "string"} },
    { "op": "save_scene", "args": {"path": "string"} },
    { "op": "introspect", "args": {"path": "string?"} }
  ],
