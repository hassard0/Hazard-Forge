# The introspection JSON golden (Slice AL) is compared BYTE-FOR-BYTE against the live --introspect
# output, which the engine writes with LF-only line endings (no BOM). Pin it to LF so a checkout on a
# CRLF-default Windows clone does not rewrite it and break the exact-match verify step.
tests/golden/introspect/*.json text eol=lf

# The material-graph introspection golden (Slice BI) is compared BYTE-FOR-BYTE against a fresh
# --material-introspect dump (material::DescribeGraphJson), which is written LF-only (no BOM). Pin to
# LF so a CRLF-default Windows checkout does not rewrite it and break the exact-match verify + test.
tests/golden/material/*.json text eol=lf

# The agent query-responses golden (Slice DX2) is compared BYTE-FOR-BYTE against a fresh --agent-query
# (scene::RunQueries), which is written LF-only (no BOM). Pin to LF so a CRLF-default Windows checkout
# does not rewrite it and break the exact-match verify step + the in-exe byte-golden proof.
tests/golden/agent/*.json text eol=lf

# The agent replay golden (Slice DX5) is compared BYTE-FOR-BYTE against a fresh --replay-record, which
# is written LF-only (no BOM). Pin to LF so a CRLF-default Windows checkout does not rewrite it and
# break the exact-match verify step + the in-exe byte-golden proof.
tests/golden/agent/*.replay text eol=lf
